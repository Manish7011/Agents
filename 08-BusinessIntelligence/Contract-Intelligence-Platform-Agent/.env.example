# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=Your-OpenAI-Key
OPENAI_MODEL=gpt-4o-mini

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/contract_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=your_super_secret_jwt_key_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8

# ── Agent MCP Ports ───────────────────────────────────────────────────────────
DRAFT_PORT=8001
REVIEW_PORT=8002
APPROVAL_PORT=8003
EXECUTION_PORT=8004
OBLIGATION_PORT=8005
COMPLIANCE_PORT=8006
ANALYTICS_PORT=8007

# ── Supervisor ────────────────────────────────────────────────────────────────
SUPERVISOR_PORT=8000

# ── UI ────────────────────────────────────────────────────────────────────────
UI_PORT=9001

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
